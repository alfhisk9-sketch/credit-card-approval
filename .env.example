# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed)
# DATABASE_URL=sqlite:///instance/credit_approval.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/credit_approval

# ── IBM Watson Machine Learning ────────────────────────────────────────────────
WATSON_API_KEY=your-ibm-watson-api-key-here
WATSON_URL=https://us-south.ml.cloud.ibm.com
WATSON_DEPLOYMENT_ID=your-deployment-id-here
WATSON_SPACE_ID=your-project-or-space-id-here
WATSON_MODEL_ID=your-model-id-here
USE_WATSON=false   # Set to true to use IBM Watson ML endpoint

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=noreply@creditpredict.ai

# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATELIMIT_STORAGE_URL=memory://
